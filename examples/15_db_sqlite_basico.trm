assíncrona função principal()
    conn = aguarde banco_conectar("sqlite:////tmp/trama_demo.db")

    aguarde banco_executar(conn, "CREATE TABLE IF NOT EXISTS usuarios (id INTEGER PRIMARY KEY, nome TEXT NOT NULL)")
    aguarde banco_executar(conn, "INSERT INTO usuarios (nome) VALUES (?)", ["ana"])

    lista = aguarde banco_consultar(conn, "SELECT id, nome FROM usuarios ORDER BY id")
    exibir(lista[0]["nome"])

    aguarde banco_fechar(conn)
fim
