assíncrona função principal()
    app = web_criar_app()
    web_saude_paths(app, "/saude", "/pronto", "/vivo")
    web_ativar_observabilidade(app)
    servidor = aguarde web_iniciar(app, "127.0.0.1", 0)
    base = servidor["base_url"]
    s = aguarde http_get(base + "/saude")
    p = aguarde http_get(base + "/pronto")
    v = aguarde http_get(base + "/vivo")
    exibir(s["status"])
    exibir(p["status"])
    exibir(v["status"])
    aguarde web_parar(servidor)
fim
