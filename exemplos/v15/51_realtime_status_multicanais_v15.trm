função h(req)
    retorne {"aceitar": verdadeiro}
fim

função principal()
    app = web_criar_app()
    web_tempo_real_rota(app, "/ws/a", h)
    web_tempo_real_rota(app, "/ws/b", h)
    web_tempo_real_rota(app, "/ws/c", h)

    st = web_tempo_real_status(app)
    exibir(st["ok"])
    exibir(tamanho(st["canais"]))
fim
