função h(req)
    retorne {"aceitar": verdadeiro}
fim

função principal()
    app = web_criar_app()
    web_tempo_real_rota(app, "/ws/manual", h)

    pub = web_tempo_real_publicar(app, "/ws/manual", "evento_manual", {"ok": verdadeiro}, {"exigir_ack": verdadeiro})
    exibir(pub["ack"])
    exibir(pub["id_mensagem"] != "")

    st = web_tempo_real_status(app, "/ws/manual")
    exibir(st["canais"][0]["pendencias_ack"])
fim
