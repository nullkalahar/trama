função h(req)
    retorne {"aceitar": verdadeiro}
fim

função principal()
    app = web_criar_app()
    web_tempo_real_rota(app, "/ws/reenvio", h)

    pub = web_tempo_real_publicar(app, "/ws/reenvio", "evento", {"n": 1}, {"exigir_ack": verdadeiro})
    out = web_tempo_real_reenviar_pendentes(app, "/ws/reenvio", pub["id_mensagem"])
    exibir(out["ok"])
    exibir(out["reenvios"])
fim
