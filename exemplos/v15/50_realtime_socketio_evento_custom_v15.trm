função eventos(req)
    se req["evento"] == "mensagem"
        retorne {"destino": "conexao", "evento": "eco_socketio", "dados": req["mensagem"]}
    fim
    retorne {"aceitar": verdadeiro}
fim

função principal()
    app = web_criar_app()
    web_websocket_rota(app, "/ws/socketio-custom", eventos)
    st = web_tempo_real_status(app, "/ws/socketio-custom")
    exibir(st["ok"])
    exibir(st["canais"][0]["canal"])
fim
