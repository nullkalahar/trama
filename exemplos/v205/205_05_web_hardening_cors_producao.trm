função ping(req)
    retorne {"status": 200, "json": {"ok": verdadeiro}}
fim

função principal()
    app = web_criar_app()
    web_rota(app, "GET", "/ping", ping)

    cfg = web_configurar_seguranca_http(
        app,
        "producao",
        ["https://app.trama.local"],
        "default-src 'self'; frame-ancestors 'none'; object-src 'none';"
    )

    exibir(cfg["ambiente"])
    exibir(tamanho(cfg["cors_origens"]) == 1)
fim
