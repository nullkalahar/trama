função api(req)
    retorne {"status": 200, "json": {"ok": verdadeiro, "usuario": req["id_usuario"]}}
fim

função principal()
    app = web_criar_app()
    web_rota(app, "GET", "/api/limite", api, nulo, {"jwt_segredo": "seg-rl-u"})

    cfg = web_rate_limit_distribuido(
        app,
        60,
        60,
        "/api/limite",
        "GET",
        ["usuario"],
        {"grupo": "g_rl_usuario", "backend": "memoria"}
    )

    exibir(cfg["ok"])
    exibir(cfg["chaves"][0] == "usuario")
fim
