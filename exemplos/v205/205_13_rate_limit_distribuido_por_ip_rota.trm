função api(req)
    retorne {"status": 200, "json": {"ok": verdadeiro}}
fim

função principal()
    app = web_criar_app()
    web_rota(app, "GET", "/api/publica", api)

    cfg = web_rate_limit_distribuido(
        app,
        120,
        60,
        "/api/publica",
        "GET",
        ["rota", "ip"],
        {"grupo": "g_rl_ip_rota", "backend": "memoria"}
    )

    exibir(cfg["ok"])
    exibir(cfg["max_requisicoes"] == 120)
    exibir(tamanho(cfg["chaves"]) == 2)
fim
