assíncrona função principal()
    app = web_criar_app()
    web_configurar_engine_http(app, "asgi", verdadeiro, 8.0)
    web_adicionar_rota_json(app, "GET", "/status", {"ok": verdadeiro, "engine": "asgi"}, 200)

    srv = aguarde web_iniciar(app, "127.0.0.1", 0)
    r = aguarde http_get(srv["base_url"] + "/status")
    exibir(r["status"] == 200)
    exibir(r["json"]["ok"])
    aguarde web_parar(srv)
fim
