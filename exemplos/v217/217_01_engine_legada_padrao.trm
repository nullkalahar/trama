assíncrona função principal()
    app = web_criar_app()
    web_adicionar_rota_json(app, "GET", "/ping", {"ok": verdadeiro}, 200)

    srv = aguarde web_iniciar(app, "127.0.0.1", 0)
    base = srv["base_url"]
    r = aguarde http_get(base + "/ping")

    exibir(r["status"] == 200)
    exibir(r["json"]["ok"])
    aguarde web_parar(srv)
fim
