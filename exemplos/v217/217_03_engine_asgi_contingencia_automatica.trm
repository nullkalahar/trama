assíncrona função principal()
    app = web_criar_app()
    web_configurar_engine_http(app, "asgi", verdadeiro, 5.0)
    web_adicionar_rota_json(app, "GET", "/pong", {"ok": verdadeiro, "modo": "contingencia_automatica"}, 200)

    srv = aguarde web_iniciar(app, "127.0.0.1", 0)
    r = aguarde http_get(srv["base_url"] + "/pong")

    exibir(r["status"] == 200)
    exibir(r["json"]["ok"])
    aguarde web_parar(srv)
fim
