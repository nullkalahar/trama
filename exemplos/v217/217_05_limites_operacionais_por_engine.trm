assíncrona função principal()
    app = web_criar_app()
    web_configurar_engine_http(app, "legada", verdadeiro, 5.0)
    web_adicionar_rota_echo_json(app, "POST", "/eco", [])

    srv = aguarde web_iniciar(app, "127.0.0.1", 0)
    base = srv["base_url"]
    ok = aguarde http_post(base + "/eco", {"nome": "trama"}, {"Content-Type": "application/json"})
    exibir(ok["status"] == 200)
    exibir(ok["json"]["ok"])

    aguarde web_parar(srv)
fim
