função ping(req)
    retorne {"status": 200, "json": {"ok": verdadeiro, "dados": {"pong": verdadeiro}}}
fim

função principal()
    app = web_criar_app()
    web_rota(app, "GET", "/api/v1/ping/:id", ping)
    spec = web_gerar_openapi(app, "API Exemplo v206", "2.0.6", "http://127.0.0.1:8080")
    exibir(spec["openapi"])
    exibir(spec["paths"]["/api/v1/ping/{id}"]["get"]["operationId"])
fim
