função health(req)
    retorne {"status": 200, "json": {"ok": verdadeiro}}
fim

assíncrona função principal()
    app = web_criar_app()
    web_rota(app, "GET", "/saude", health)
    web_ativar_observabilidade(app, "/observabilidade", "/alertas", {"erro_percentual_limite": 0.2, "latencia_ms_limite": 500, "requisicoes_minimas": 1})
    s = aguarde web_iniciar(app, "127.0.0.1", 8083)
    exibir(s["base_url"])
    aguarde web_parar(s)
fim
