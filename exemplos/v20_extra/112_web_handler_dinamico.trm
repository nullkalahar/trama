função rota_usuario(req)
    uid = req["parametros"]["id"]
    retorne {"status": 200, "dados": {"id": uid, "nome": "u_" + uid}}
fim

assíncrona função principal()
    app = web_criar_app()
    web_rota(app, "GET", "/usuarios/:id", rota_usuario, {}, {})

    srv = aguarde web_iniciar(app, "127.0.0.1", 8131)
    r = aguarde http_get(srv["base_url"] + "/usuarios/42")
    exibir(r["json"]["dados"]["id"])
    aguarde web_parar(srv)
fim
