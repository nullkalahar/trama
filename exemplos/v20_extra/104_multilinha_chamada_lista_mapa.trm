função soma(a, b, c)
    retorne a + b + c
fim

função principal()
    numeros = [
        10,
        20,
        30
    ]

    cfg = {
        "limites": {
            "min": 1,
            "max": 100
        }
    }

    total = soma(
        numeros[0],
        numeros[1],
        numeros[2]
    )

    exibir(total)
    exibir(cfg["limites"]["max"])
fim
