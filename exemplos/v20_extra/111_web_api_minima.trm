função rota_status(req)
    retorne {"status": 200, "dados": {"ok": verdadeiro}}
fim

assíncrona função principal()
    app = web_criar_app()
    web_rota(app, "GET", "/status", rota_status, {}, {})

    srv = aguarde web_iniciar(app, "127.0.0.1", 8130)
    exibir(srv["base_url"])
    aguarde web_parar(srv)
fim
