função principal()
    valores = [1, 2, 3, 4, 5, 6]
    soma_pares = 0

    para valor em valores
        se valor == 3
            continue
        fim

        se valor > 5
            pare
        fim

        se valor == 2
            soma_pares = soma_pares + valor
        fim

        se valor == 4
            soma_pares = soma_pares + valor
        fim
    fim

    exibir(soma_pares)
fim
