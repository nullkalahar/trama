função chat(req)
    retorne {"aceitar": verdadeiro}
fim

assíncrona função principal()
    app = web_criar_app()
    web_tempo_real_rota(app, "/ws/admin", chat)
    web_tempo_real_ativar_fallback(app)
    s = aguarde web_iniciar(app, "127.0.0.1", 8109)
    st = web_tempo_real_status(app)
    exibir(st["ok"])
    exibir(st["fallback_ativo"])
    exibir(st["fallback_prefixo"])
    aguarde web_parar(s)
fim
