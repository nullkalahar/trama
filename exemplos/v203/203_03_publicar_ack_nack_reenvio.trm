função h(req)
    retorne {"aceitar": verdadeiro}
fim

função principal()
    app = web_criar_app()
    web_tempo_real_rota(app, "/ws/v203", h)
    pub = web_tempo_real_publicar(app, "/ws/v203", "evt", {"ok": verdadeiro}, {"exigir_ack": verdadeiro})
    exibir(pub["ack"])
    exibir(pub["cursor"] > 0)
    exibir(web_tempo_real_reenviar_pendentes(app, "/ws/v203", pub["id_mensagem"])["ok"])
fim
