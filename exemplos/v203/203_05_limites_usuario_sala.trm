função h(req)
    retorne {"aceitar": verdadeiro}
fim

função principal()
    app = web_criar_app()
    web_tempo_real_rota(app, "/ws/lim", h)
    web_tempo_real_definir_limites(app, {"max_mensagens_por_janela": 10, "max_mensagens_por_janela_usuario": 2, "max_mensagens_por_janela_sala": 2, "janela_rate_segundos": 60})
    st = web_tempo_real_status(app, "/ws/lim")
    exibir(st["limites"]["max_mensagens_por_janela_usuario"])
    exibir(st["limites"]["max_mensagens_por_janela_sala"])
fim
