função envelope_ok_25(dados)
    retorne {
        "ok": verdadeiro,
        "dados": dados,
        "erro": nulo,
        "meta": {"versao": "v2.1.3"}
    }
fim

função envelope_erro_25(codigo, mensagem)
    retorne {
        "ok": falso,
        "dados": nulo,
        "erro": {"codigo": codigo, "mensagem": mensagem, "detalhes": {}},
        "meta": {"versao": "v2.1.3"}
    }
fim

função principal()
    se 25 > 20
        exibir(envelope_ok_25({"rota": "/api/v1/exemplo"}))
    senão
        exibir(envelope_erro_25("VALIDACAO_FALHOU", "payload invalido"))
    fim
fim
