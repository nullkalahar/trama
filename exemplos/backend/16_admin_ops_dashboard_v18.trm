função ok(req)
    retorne {"status": 200, "json": {"ok": verdadeiro}}
fim

assíncrona função principal()
    app = web_criar_app()
    web_rota(app, "GET", "/ok", ok)
    web_ativar_observabilidade(app)

    s = aguarde web_iniciar(app, "127.0.0.1", 0)
    b = s["base_url"]

    aguarde http_get(b + "/ok")
    exibir((aguarde http_get(b + "/observabilidade"))["status"])
    exibir((aguarde http_get(b + "/alertas"))["status"])

    aguarde web_parar(s)
fim
