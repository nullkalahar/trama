função h(req)
    retorne {"aceitar": verdadeiro}
fim

assíncrona função principal()
    app = web_criar_app()
    web_tempo_real_rota(app, "/ws/eng", h)
    web_tempo_real_ativar_fallback(app)
    srv = aguarde web_iniciar(app, "127.0.0.1", 0)
    base = srv["base_url"]

    st = aguarde http_get(base + "/tempo-real/fallback/status")
    exibir(st["status"] == 200)
    exibir(st["json"]["ok"])

    aguarde web_parar(srv)
fim
