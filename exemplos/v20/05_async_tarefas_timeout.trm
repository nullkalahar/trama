assíncrona função trabalho(nome, tempo)
    aguarde dormir(tempo)
    retorne "ok:" + nome
fim

assíncrona função principal()
    t1 = criar_tarefa(trabalho("a", 0.02))
    t2 = criar_tarefa(trabalho("b", 0.03))

    r1 = aguarde com_timeout(t1, 1)
    r2 = aguarde com_timeout(t2, 1)

    exibir(r1)
    exibir(r2)
fim
